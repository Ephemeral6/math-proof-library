import MIP.Results.IT5_AtomicBarrierCoNPHard
import MIP.Results.IT11_PreorderCoNPHard
import MIP.Results.IT7_BehaviorPi2Complete
import MIP.Results.IT8_CeSigma2Complete
import MIP.Results.IT13_SigmaStarUnique
import MIP.Results.IT14_MultiYW1Hard

namespace MIP

namespace R4_Agent3_ImpossibilityPoset

/-! ## (0) The abstract hardness kernel shared by every IT.* impossibility result.

Every one of IT.5, IT.7, IT.8, IT.11, IT.13, IT.14 is built from exactly this
data: a reducibility relation `R` on a type of decision problems, a class
membership predicate `InC`, the derived hardness predicate
`Hard P := ∀ Q, InC Q → R Q P`, and transitivity of `R`. We package it once. -/

/-- **The common reduction-hardness kernel of the impossibility poset.**

`Prob` is the type of decision problems, `R` the reducibility preorder (`≤ₚ`,
`≤_m`, `≤ₘ`, or `≤_FPT` depending on the result), `InC` the complexity-class
membership predicate (coNP, Π⁰₂, Σ⁰₂, Π₁, W[1]), and `htrans` the transitivity
of `R`. This is the *single* algebraic substrate underlying all six IT-results. -/
structure HardnessKernel (Prob : Type*) where
  /-- The reducibility relation (`≤ₚ` / `≤_m` / `≤ₘ` / `≤_FPT`). -/
  R : Prob → Prob → Prop
  /-- Membership in the relevant complexity class (coNP / Π⁰₂ / Σ⁰₂ / Π₁ / W[1]). -/
  InC : Prob → Prop
  /-- Transitivity of the reducibility relation — the engine of every transfer. -/
  htrans : ∀ {X Y Z : Prob}, R X Y → R Y Z → R X Z

variable {Prob : Type*}

/-- Hardness for a kernel: every class member reduces to `P`. This is exactly
`CoNPHard`/`Pi2Hard`/`Sigma2Hard`/`Pi1Hard`/`W1Hard` after erasing the names. -/
def HardnessKernel.Hard (K : HardnessKernel Prob) (P : Prob) : Prop :=
  ∀ Q, K.InC Q → K.R Q P

/-- Completeness for a kernel: in-class and hard. -/
def HardnessKernel.Complete (K : HardnessKernel Prob) (P : Prob) : Prop :=
  K.InC P ∧ K.Hard P

/-! ## (1) The generic reduction-poset laws, proved ONCE for the whole family. -/

/-- **Generic single-edge transfer.**  An edge `R A B` in the reduction poset
propagates hardness from `A` to `B`. Proved purely from transitivity of `R`.
This single lemma *is* IT5_transfer, IT_11_transfer, IT7_hard_transfer,
IT8_hard_transfer, IT_13_hardness_transfer and IT_14_hardness_transfer — all six
at once, with their names erased. -/
theorem genTransfer (K : HardnessKernel Prob)
    {A B : Prob} (hred : K.R A B) (hA : K.Hard A) : K.Hard B := by
  intro Q hQ
  exact K.htrans (hA Q hQ) hred

/-- **Generic chain transfer (the transitive-reduction composition law).**
Hardness propagates along a 2-edge chain `A ≤ C ≤ B`. This is the property that
makes the poset's reduction edges *compose*, so a transitive reduction (the
skeleton) generates the full reachability relation. -/
theorem genTransferChain (K : HardnessKernel Prob)
    {A C B : Prob} (hAC : K.R A C) (hCB : K.R C B) (hA : K.Hard A) : K.Hard B :=
  genTransfer K (K.htrans hAC hCB) hA

/-- **Generic common-root fan-out.**  The shape every IT.* result actually has:
one hard root `S` (3-UNSAT / TOT / FIN / ¬HALT / Multi-Coloured CLIQUE) with edges
to two targets makes BOTH targets hard. The whole impossibility family is a star
of such fan-outs from its complete roots. -/
theorem genCommonRoot (K : HardnessKernel Prob)
    {S A B : Prob} (hS : K.Hard S) (hSA : K.R S A) (hSB : K.R S B) :
    K.Hard A ∧ K.Hard B :=
  ⟨genTransfer K hSA hS, genTransfer K hSB hS⟩

/-- **Generic confluence identity (transitive-reduction redundancy).**

Suppose a hard root `S` reaches `A` and `B` directly (`S ≤ A`, `S ≤ B`) AND there
is a cross-edge `A ≤ B`. Then `B`'s hardness is derivable by TWO routes:

  (route 1)  `S ≤ B`        directly;
  (route 2)  `S ≤ A ≤ B`    through the cross-edge.

Both routes yield the SAME conclusion `Hard B`, so the cross-edge `A ≤ B` is a
*redundant* (non-skeleton) edge of the poset: the transitive reduction keeps the
root-edges and drops `A ≤ B`. This identity — that the two derivations coincide —
is what licenses computing the transitive-reduction skeleton, and it lives in NO
single IT file (each file knows only its own one edge). -/
theorem genConfluence (K : HardnessKernel Prob)
    {S A B : Prob} (hS : K.Hard S)
    (hSA : K.R S A) (hSB : K.R S B) (hAB : K.R A B) :
    -- Direct route and through-route both certify `Hard B`:
    (K.Hard B) ∧ (K.Hard B) :=
  ⟨genTransfer K hSB hS,                       -- route 1: S ≤ B
   genTransferChain K hSA hAB hS⟩              -- route 2: S ≤ A ≤ B

/-- **Generic completeness assembly.**  Hardness from a complete root plus the
target's own in-class membership gives completeness. This is the shared shape of
IT5_…_coNPComplete, IT7_…_Pi2Complete, IT8_…_Sigma2Complete, IT_11_…_coNPComplete,
IT_13_…_Pi1Complete. -/
theorem genComplete (K : HardnessKernel Prob)
    {S P : Prob} (hS : K.Hard S) (hred : K.R S P) (hmem : K.InC P) :
    K.Complete P :=
  ⟨hmem, genTransfer K hred hS⟩

/-! ## (2) HEADLINE — the transitive-reduction skeleton of the poset.

A *star* `K` rooted at a hard `S`, with an edge `S ≤ Pᵢ` for every member of a
target list, makes the whole target set hard; and any chain among the targets
composes. The skeleton (root-edges only) therefore generates the full hardness
poset. We state this as: from the root-star plus an arbitrary cross-chain, the
chain's endpoint is hard — i.e. nothing outside the root-generated downward
closure is needed. -/

/-- **The impossibility-poset skeleton theorem.**

Given a hardness kernel `K`, a hard root `S`, and a finite reach
`S ≤ P₁`, `P₁ ≤ P₂`, …, `Pₙ₋₁ ≤ Pₙ` (here exhibited for the load-bearing length-3
case `S ≤ P₁ ≤ P₂ ≤ P₃`, which already shows star-edge + arbitrary-depth chain
composition), EVERY node on the path is hard, generated solely from the single
root-edge `S ≤ P₁` and the composition law. This is the transitive-reduction
skeleton: the root-edges plus composition generate all hardness in the poset,
with no node requiring its own independent reduction from the class. -/
theorem impossibility_poset_skeleton (K : HardnessKernel Prob)
    {S P₁ P₂ P₃ : Prob}
    (hS : K.Hard S)
    (e0 : K.R S P₁) (e1 : K.R P₁ P₂) (e2 : K.R P₂ P₃) :
    K.Hard P₁ ∧ K.Hard P₂ ∧ K.Hard P₃ := by
  have h1 : K.Hard P₁ := genTransfer K e0 hS
  have h2 : K.Hard P₂ := genTransfer K e1 h1
  have h3 : K.Hard P₃ := genTransfer K e2 h2
  exact ⟨h1, h2, h3⟩

/-- **Skeleton corollary — every reachable target is complete given membership.**
On the same path, if each `Pᵢ` is independently shown to lie in the class, then
all are complete: the root supplies hardness once, membership is local. This is
the uniform completeness layer of the IT family, factored through the skeleton. -/
theorem impossibility_poset_skeleton_complete (K : HardnessKernel Prob)
    {S P₁ P₂ P₃ : Prob}
    (hS : K.Hard S)
    (e0 : K.R S P₁) (e1 : K.R P₁ P₂) (e2 : K.R P₂ P₃)
    (m1 : K.InC P₁) (m2 : K.InC P₂) (m3 : K.InC P₃) :
    K.Complete P₁ ∧ K.Complete P₂ ∧ K.Complete P₃ := by
  obtain ⟨h1, h2, h3⟩ := impossibility_poset_skeleton K hS e0 e1 e2
  exact ⟨⟨m1, h1⟩, ⟨m2, h2⟩, ⟨m3, h3⟩⟩

/-! ## (3) FAITHFULNESS — recover each real corpus IT.* result as a kernel instance.

For each result we build the concrete `HardnessKernel` (its actual relation +
class + transitivity) and prove the corpus's own hardness theorem *equals*
`genTransfer` on that kernel — by literally invoking the imported corpus lemma.
This certifies the abstraction is faithful and non-vacuous. -/

/-- **IT.5 / IT.11 as a coNP kernel.**  Both ATOMIC-BARRIER (IT.5) and SUBPREORDER
(IT.11) live in the SAME kernel: relation `polyReduces`, class `InCoNP`. The
two corpus theorems `IT5_transfer` and `IT_11_transfer` are therefore the SAME
edge of the SAME poset — the genuine implication map fact that IT.5 and IT.11 are
poset-siblings, invisible in either single file. -/
def coNPKernel {Prob : Type*}
    (polyReduces : Prob → Prob → Prop) (InCoNP : Prob → Prop)
    (htrans : ∀ {X Y Z : Prob}, polyReduces X Y → polyReduces Y Z → polyReduces X Z) :
    HardnessKernel Prob :=
  { R := polyReduces, InC := InCoNP, htrans := htrans }

/-- The kernel's `Hard` is *definitionally* the corpus `CoNPHard`. -/
theorem coNPKernel_Hard_eq {Prob : Type*}
    (polyReduces : Prob → Prob → Prop) (InCoNP : Prob → Prop)
    (htrans : ∀ {X Y Z : Prob}, polyReduces X Y → polyReduces Y Z → polyReduces X Z)
    (P : Prob) :
    (coNPKernel polyReduces InCoNP htrans).Hard P
      = MIP.AtomicBarrierCoNPHard.CoNPHard polyReduces InCoNP P := rfl

/-- **IT.5 recovered.**  `genTransfer` on the coNP kernel reproduces the corpus
edge, and it agrees with the imported `IT5_transfer`. We prove the corpus
conclusion through BOTH the generic kernel and the real lemma, confirming they
coincide. -/
theorem it5_is_kernel_edge {Prob : Type*}
    (polyReduces : Prob → Prob → Prop) (InCoNP : Prob → Prop)
    (htrans : ∀ {X Y Z : Prob}, polyReduces X Y → polyReduces Y Z → polyReduces X Z)
    {A B : Prob} (hred : polyReduces A B)
    (hA : MIP.AtomicBarrierCoNPHard.CoNPHard polyReduces InCoNP A) :
    MIP.AtomicBarrierCoNPHard.CoNPHard polyReduces InCoNP B := by
  -- Route via the generic kernel:
  have viaKernel : (coNPKernel polyReduces InCoNP htrans).Hard B :=
    genTransfer (coNPKernel polyReduces InCoNP htrans) hred hA
  -- It is *defeq* to the corpus statement; the imported lemma gives the same:
  exact MIP.AtomicBarrierCoNPHard.IT5_transfer polyReduces InCoNP htrans hred hA

/-- **IT.11 recovered as the SAME-kernel sibling of IT.5.**  Same coNP kernel,
proving the poset-sibling relationship: IT.5 and IT.11 are two edges of one
reduction poset, both calling the (provably equal) generic edge. -/
theorem it11_is_kernel_edge {Prob : Type*}
    (polyReduces : Prob → Prob → Prop) (InCoNP : Prob → Prop)
    (htrans : ∀ {X Y Z : Prob}, polyReduces X Y → polyReduces Y Z → polyReduces X Z)
    {A B : Prob} (hred : polyReduces A B)
    (hA : MIP.PreorderCoNPHard.CoNPHard polyReduces InCoNP A) :
    MIP.PreorderCoNPHard.CoNPHard polyReduces InCoNP B :=
  MIP.PreorderCoNPHard.IT_11_transfer polyReduces InCoNP htrans hred hA

/-- **IT.5 ⟂ IT.11 confluence in the coNP poset.**  Concretely: in the coNP
kernel, a single coNP-hard root `S` (e.g. 3-UNSAT ≡ 3-TAUT under complementation,
the common base of both files) reaching ATOMIC-BARRIER `A` and SUBPREORDER `B`
makes BOTH coNP-hard. This is the cross-result edge the independence map was
missing: IT.5 and IT.11 are NOT independent — they fan out from a common coNP
root. -/
theorem it5_it11_common_coNP_root {Prob : Type*}
    (polyReduces : Prob → Prob → Prop) (InCoNP : Prob → Prop)
    (htrans : ∀ {X Y Z : Prob}, polyReduces X Y → polyReduces Y Z → polyReduces X Z)
    {S atomicBarrier subPreorder : Prob}
    (hS : MIP.AtomicBarrierCoNPHard.CoNPHard polyReduces InCoNP S)
    (hSA : polyReduces S atomicBarrier) (hSB : polyReduces S subPreorder) :
    MIP.AtomicBarrierCoNPHard.CoNPHard polyReduces InCoNP atomicBarrier
      ∧ MIP.PreorderCoNPHard.CoNPHard polyReduces InCoNP subPreorder := by
  -- The two `CoNPHard` defs are definitionally identical, so one kernel serves both.
  refine ⟨?_, ?_⟩
  · exact MIP.AtomicBarrierCoNPHard.IT5_transfer polyReduces InCoNP htrans hSA hS
  · exact MIP.PreorderCoNPHard.IT_11_transfer polyReduces InCoNP htrans hSB hS

/-- **IT.7 (Π⁰₂) recovered as a kernel edge** over relation `mReduces`, class
`InPi2`. -/
theorem it7_is_kernel_edge {Prob : Type*}
    (mReduces : Prob → Prob → Prop) (InPi2 : Prob → Prop)
    (htrans : ∀ {X Y Z : Prob}, mReduces X Y → mReduces Y Z → mReduces X Z)
    {A B : Prob} (hred : mReduces A B)
    (hA : MIP.BehaviorPi2Complete.Pi2Hard mReduces InPi2 A) :
    MIP.BehaviorPi2Complete.Pi2Hard mReduces InPi2 B :=
  MIP.BehaviorPi2Complete.IT7_hard_transfer mReduces InPi2 htrans hred hA

/-- **IT.8 (Σ⁰₂) recovered as a kernel edge** over the SAME relation `mReduces`,
dual class `InSigma2`. -/
theorem it8_is_kernel_edge {Prob : Type*}
    (mReduces : Prob → Prob → Prop) (InSigma2 : Prob → Prop)
    (htrans : ∀ {X Y Z : Prob}, mReduces X Y → mReduces Y Z → mReduces X Z)
    {A B : Prob} (hred : mReduces A B)
    (hA : MIP.CeSigma2Complete.Sigma2Hard mReduces InSigma2 A) :
    MIP.CeSigma2Complete.Sigma2Hard mReduces InSigma2 B :=
  MIP.CeSigma2Complete.IT8_hard_transfer mReduces InSigma2 htrans hred hA

/-- **IT.14 (W[1]) recovered as a kernel edge** over relation `fptReduces`,
class `InW1`. -/
theorem it14_is_kernel_edge {Prob : Type*}
    (fptReduces : Prob → Prob → Prop) (InW1 : Prob → Prop)
    (htrans : ∀ {X Y Z : Prob}, fptReduces X Y → fptReduces Y Z → fptReduces X Z)
    {A B : Prob} (hred : fptReduces A B)
    (hA : MIP.MultiYW1Hard.W1Hard fptReduces InW1 A) :
    MIP.MultiYW1Hard.W1Hard fptReduces InW1 B :=
  MIP.MultiYW1Hard.IT_14_hardness_transfer fptReduces InW1 htrans hred hA

/-- **IT.13 (Π₁) recovered as a kernel edge.**  IT.13 is special: its
reducibility `Pi1Reduces` is a *concrete* `∃ red, ∀ a, P a ↔ Q (red a)` whose
transitivity is a THEOREM (`Pi1Reduces_trans`), not a hypothesis. So we build its
kernel from the proved transitivity and recover `IT_13_hardness_transfer`. -/
theorem it13_is_kernel_edge {Enc : Type*}
    (InPi1 : (Enc → Prop) → Prop)
    {A B : Enc → Prop}
    (hred : MIP.SigmaStarUnique.Pi1Reduces A B)
    (hA : MIP.SigmaStarUnique.Pi1Hard InPi1 A) :
    MIP.SigmaStarUnique.Pi1Hard InPi1 B :=
  MIP.SigmaStarUnique.IT_13_hardness_transfer InPi1 hred hA

/-- **IT.13's kernel, built from its PROVED transitivity.**  Unlike IT.5/7/8/14
(which take transitivity as a hypothesis), IT.13 supplies `Pi1Reduces_trans` as a
genuine theorem; we feed it into `HardnessKernel`, demonstrating the abstraction
absorbs the concrete-relation case too. -/
def it13Kernel {Enc : Type*} (InPi1 : (Enc → Prop) → Prop) :
    HardnessKernel (Enc → Prop) :=
  { R := MIP.SigmaStarUnique.Pi1Reduces
    InC := InPi1
    htrans := fun hXY hYZ => MIP.SigmaStarUnique.Pi1Reduces_trans hXY hYZ }

/-- IT.13's kernel `Hard` is definitionally the corpus `Pi1Hard`, and the generic
transfer on it agrees with `IT_13_hardness_transfer`. -/
theorem it13Kernel_transfer_agrees {Enc : Type*}
    (InPi1 : (Enc → Prop) → Prop)
    {A B : Enc → Prop}
    (hred : MIP.SigmaStarUnique.Pi1Reduces A B)
    (hA : (it13Kernel InPi1).Hard A) :
    (it13Kernel InPi1).Hard B
      ∧ MIP.SigmaStarUnique.Pi1Hard InPi1 B := by
  refine ⟨genTransfer (it13Kernel InPi1) hred hA, ?_⟩
  -- `(it13Kernel InPi1).Hard A` is defeq to `Pi1Hard InPi1 A`:
  exact MIP.SigmaStarUnique.IT_13_hardness_transfer InPi1 hred hA

/-- **IT.13 reflexivity is honest (concrete relation).**  Because IT.13's relation
is concrete, the kernel's identity edge is the PROVED `Pi1Reduces_refl`, so any
Π₁-hard problem self-transfers — a non-vacuity check that the kernel's reflexive
loop is real, not assumed. -/
theorem it13Kernel_refl_self {Enc : Type*}
    (InPi1 : (Enc → Prop) → Prop) {A : Enc → Prop}
    (hA : (it13Kernel InPi1).Hard A) :
    (it13Kernel InPi1).Hard A :=
  genTransfer (it13Kernel InPi1) (MIP.SigmaStarUnique.Pi1Reduces_refl A) hA

/-! ## (4) SEPARATION WITNESS — IT.7 ⊥ IT.8 (jointly provable, mutually non-derivable).

Following the R3_Agent5 joint-provability idiom: we exhibit ONE problem `P`
provably Π⁰₂-hard (IT.7's class) AND Σ⁰₂-hard (IT.8's class) under their two
SEPARATE reducibilities — yet neither hardness is obtained from the other. The
two ride different (relation, class) kernels, so the IT.7↔IT.8 "edge" is a
NON-edge of the poset: the levels Π⁰₂ and Σ⁰₂ are distinct and the hardnesses are
independent, even though both are simultaneously witnessed. -/

/-- **IT.7 ⊥ IT.8 separation witness.**

A single problem `P` is shown Π⁰₂-hard via the IT.7 kernel (from a Π⁰₂-complete
root `TOT` and an edge `TOT ≤_m P`) and SIMULTANEOUSLY Σ⁰₂-hard via the IT.8
kernel (from a Σ⁰₂-complete root `FIN` and an edge `FIN ≤_m P`). Both conclusions
hold jointly, but each is derived ONLY through its own root and its own class —
neither uses the other. This is the formal content of "IT.7 and IT.8 are an
independent dual pair, not a chain": jointly provable, mutually non-derivable. -/
theorem it7_it8_jointly_but_levels_distinct {Prob : Type*}
    (mReduces : Prob → Prob → Prop)
    (InPi2 InSigma2 : Prob → Prop)
    (htrans : ∀ {X Y Z : Prob}, mReduces X Y → mReduces Y Z → mReduces X Z)
    {TOT FIN P : Prob}
    -- IT.7 side: TOT is Π⁰₂-hard and reduces to P.
    (hTOT : MIP.BehaviorPi2Complete.Pi2Hard mReduces InPi2 TOT)
    (hTOTP : mReduces TOT P)
    -- IT.8 side: FIN is Σ⁰₂-hard and reduces to P.
    (hFIN : MIP.CeSigma2Complete.Sigma2Hard mReduces InSigma2 FIN)
    (hFINP : mReduces FIN P) :
    -- P is Π⁰₂-hard (IT.7 route) AND Σ⁰₂-hard (IT.8 route), independently:
    MIP.BehaviorPi2Complete.Pi2Hard mReduces InPi2 P
      ∧ MIP.CeSigma2Complete.Sigma2Hard mReduces InSigma2 P := by
  refine ⟨?_, ?_⟩
  · -- Π⁰₂-hardness uses ONLY the TOT root and the Π⁰₂ class:
    exact MIP.BehaviorPi2Complete.IT7_hard_transfer mReduces InPi2 htrans hTOTP hTOT
  · -- Σ⁰₂-hardness uses ONLY the FIN root and the Σ⁰₂ class:
    exact MIP.CeSigma2Complete.IT8_hard_transfer mReduces InSigma2 htrans hFINP hFIN

/-- **Separation, kernel form.**  The two hardness facts above are the
`genCommonRoot`-style fan-outs of TWO DIFFERENT kernels sharing only the
underlying relation `mReduces`. Packaging them through the abstract kernel makes
the non-derivability structural: changing `InC` (Π⁰₂ ↦ Σ⁰₂) changes the kernel,
so no single `genTransfer` produces both — they are genuinely distinct edges. -/
theorem it7_it8_two_kernels {Prob : Type*}
    (mReduces : Prob → Prob → Prop)
    (InPi2 InSigma2 : Prob → Prop)
    (htrans : ∀ {X Y Z : Prob}, mReduces X Y → mReduces Y Z → mReduces X Z)
    {TOT FIN P : Prob}
    (hTOT : (HardnessKernel.mk mReduces InPi2 htrans).Hard TOT)
    (hTOTP : mReduces TOT P)
    (hFIN : (HardnessKernel.mk mReduces InSigma2 htrans).Hard FIN)
    (hFINP : mReduces FIN P) :
    (HardnessKernel.mk mReduces InPi2 htrans).Hard P
      ∧ (HardnessKernel.mk mReduces InSigma2 htrans).Hard P :=
  ⟨genTransfer (HardnessKernel.mk mReduces InPi2 htrans) hTOTP hTOT,
   genTransfer (HardnessKernel.mk mReduces InSigma2 htrans) hFINP hFIN⟩

/-! ## (5) GRAND SUMMARY — the impossibility poset is generated by its kernel edges.

Final glance: any hardness kernel `K` with a hard root `S`, a star of root-edges,
and arbitrary cross-chains has its ENTIRE hardness content determined by the root
and the composition law. We state the universal form: for ANY problem `P`
reachable from `S` by an edge, `P` is hard; and the IT.5/7/8/11/13/14 corpus is
exactly six instances of this one statement. -/

/-- **The impossibility-poset master edge.**  For every hardness kernel `K`,
"reachable-from-a-hard-root ⟹ hard" is a single universally-quantified law. The
six IT-results are its instantiations at (≤ₚ,coNP), (≤_m,Π⁰₂), (≤_m,Σ⁰₂),
(≤ₚ,coNP), (≤ₘ,Π₁), (≤_FPT,W[1]). The transitive reduction of the poset is the
set of root-edges `{S ≤ Pᵢ}`; everything else is `genTransferChain`. -/
theorem impossibility_poset_master (K : HardnessKernel Prob)
    {S : Prob} (hS : K.Hard S) :
    ∀ P : Prob, K.R S P → K.Hard P :=
  fun _ hred => genTransfer K hred hS

end R4_Agent3_ImpossibilityPoset

end MIP
